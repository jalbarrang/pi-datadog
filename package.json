{
  "name": "@dreki-gg/pi-datadog",
  "version": "0.4.0",
  "description": "Datadog log search tools for pi \u2014 query production logs with project-aware context",
  "keywords": [
    "pi-package",
    "pi",
    "datadog",
    "logs",
    "observability"
  ],
  "author": "Juan Albarran <jalbarrandev@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jalbarrang/pi-datadog.git"
  },
  "type": "module",
  "files": [
    "extensions",
    "README.md",
    "CHANGELOG.md",
    "package.json"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "lint": "oxlint extensions test",
    "format": "oxfmt --write extensions test",
    "format:check": "oxfmt --check extensions test"
  },
  "pi": {
    "extensions": [
      "./extensions/datadog"
    ]
  },
  "dependencies": {
    "@datadog/datadog-api-client": "^1.60.0"
  },
  "devDependencies": {
    "@types/node": "26",
    "bun-types": "^1.3.14",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "typescript": "^7.0.2",
    "@earendil-works/pi-coding-agent": "^0.80.6",
    "typebox": "^1.3.6"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "typebox": "*"
  },
  "peerDependenciesMeta": {
    "@earendil-works/pi-coding-agent": {
      "optional": true
    },
    "typebox": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  }
}
